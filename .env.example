# Telemt API
TELEMT_API=http://127.0.0.1:9091
TELEMT_AUTH=Bearer YOUR_API_TOKEN

# Панель управления
PANEL_URL=https://panel.yourdomain.com:8443
PANEL_USER=admin
PANEL_PASS=YOUR_PANEL_PASSWORD

# Telegram бот
BOT_TOKEN=YOUR_BOT_TOKEN
CHAT_ID=YOUR_TELEGRAM_ID

# Пути
DATA_DIR=/var/www/stats/data

# Белый список — пароль для веб-интерфейса
WL_PASSWORD=YOUR_WHITELIST_PASSWORD

# Домен
SITE_DOMAIN=tg.yourdomain.com
SITE_CHANNEL=@yourchannel
PANEL_URL_PUBLIC=https://panel.yourdomain.com:8443
